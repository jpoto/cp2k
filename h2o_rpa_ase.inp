&GLOBAL
  PROJECT h2o_rpa_ase
  RUN_TYPE ENERGY_FORCE
  PRINT_LEVEL MEDIUM
&

&FORCE_EVAL
  METHOD Quickstep
  &DFT
    BASIS_SET_FILE_NAME BASIS_MOLOPT
    POTENTIAL_FILE_NAME GTH_POTENTIALS
    
    &QS
      METHOD GPW
      EPS_DEFAULT 1.0E-12
    &
    
    &SCF
      MAX_SCF 50
      EPS_SCF 1.0E-6
      SCF_GUESS ATOMIC
      &OT
        MINIMIZER DIIS
        PRECONDITIONER FULL_SINGLE_INVERSE
      &
    &
    
    &XC
      &XC_FUNCTIONAL PBE
      &
    &
    
    &RPA
      METHOD GPW
      RI_RPA TRUE
      MEMORY
        EPS_STORAGE_SCALING 0.1
      &
    &
  &
  
  &SUBSYS
    &CELL
      ABC 10.0 10.0 10.0
      PERIODIC NONE
    &
    &COORD
      H         5.000000        5.000000        5.000000
      H         5.958000        5.000000        5.000000
      O         5.000000        5.958000        5.000000
    &
    &KIND H
      BASIS_SET DZVP-MOLOPT-SR-GTH
      POTENTIAL GTH-PBE
    &
    &KIND H
      BASIS_SET DZVP-MOLOPT-SR-GTH
      POTENTIAL GTH-PBE
    &
    &KIND O
      BASIS_SET DZVP-MOLOPT-SR-GTH
      POTENTIAL GTH-PBE
    &
  &
&
