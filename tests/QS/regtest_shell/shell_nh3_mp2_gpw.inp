&GLOBAL
  PRINT_LEVEL LOW
  PROJECT shell_nh3_mp2_gpw
  RUN_TYPE ENERGY
&END GLOBAL

&FORCE_EVAL
  METHOD Quickstep
  &DFT
    BASIS_SET_FILE_NAME HFX_BASIS
    POTENTIAL_FILE_NAME POTENTIAL
    &MGRID
      CUTOFF 300
      REL_CUTOFF 40
    &END MGRID
    &POISSON
      PERIODIC NONE
      POISSON_SOLVER MT
    &END POISSON
    &QS
      EPS_DEFAULT 1.0E-12
      METHOD GPW
    &END QS
    &SCF
      MAX_SCF 50
      EPS_SCF 1.0E-5
      SCF_GUESS ATOMIC
      IGNORE_CONVERGENCE_FAILURE
    &END SCF
    &XC
      &HF
        FRACTION 1.0
        &SCREENING
          EPS_SCHWARZ 1.0E-6
        &END SCREENING
      &END HF
      &WF_CORRELATION
        MEMORY 50
        &MP2
          METHOD MP2_GPW
        &END MP2
      &END WF_CORRELATION
      &XC_FUNCTIONAL NONE
      &END XC_FUNCTIONAL
    &END XC
  &END DFT
  &SUBSYS
    &CELL
      ABC 12.0 12.0 12.0
      PERIODIC NONE
    &END CELL
    &COORD
N    0.000000    0.000000    0.000000
H    0.000000    0.939853    0.000000
H    0.813599   -0.313284    0.000000
H   -0.813599   -0.313284    0.000000
    &END COORD
    &KIND N
      BASIS_SET DZVP-GTH
      BASIS_SET RI_AUX RI_DZVP-GTH
      POTENTIAL GTH-PBE-q5
    &END KIND
    &KIND H
      BASIS_SET DZVP-GTH
      BASIS_SET RI_AUX RI_DZVP-GTH
      POTENTIAL GTH-PBE-q1
    &END KIND
  &END SUBSYS
&END FORCE_EVAL