&GLOBAL
  PRINT_LEVEL LOW
  PROJECT shell_dftb
  RUN_TYPE ENERGY
&END GLOBAL

#CPQA INCLUDE DFTB/nonscc/nonscc_parameter
#CPQA INCLUDE uff_table
#CPQA INCLUDE DFTB/nonscc/oo
#CPQA INCLUDE DFTB/nonscc/oc
#CPQA INCLUDE DFTB/nonscc/oh
#CPQA INCLUDE DFTB/nonscc/co
#CPQA INCLUDE DFTB/nonscc/cc
#CPQA INCLUDE DFTB/nonscc/ch
#CPQA INCLUDE DFTB/nonscc/hh

&FORCE_EVAL
  &DFT
    &QS
      METHOD DFTB
      &DFTB
        DISPERSION F
        ORTHOGONAL_BASIS F
        SELF_CONSISTENT F
        &PARAMETER
          PARAM_FILE_NAME nonscc_parameter
          PARAM_FILE_PATH DFTB/nonscc
          UFF_FORCE_FIELD uff_table
        &END PARAMETER
      &END DFTB
    &END QS
    &SCF
      MAX_SCF 50
      SCF_GUESS ATOMIC
      &MIXING
        ALPHA 1.
        METHOD DIRECT_P_MIXING
      &END MIXING
    &END SCF
  &END DFT
  &SUBSYS
    &CELL
      ABC 20.0 20.0 20.0
      PERIODIC NONE
    &END CELL
    &COORD
      O    0.000000    0.000000    0.000000
      H    0.000000    0.757154    0.586295
      H    0.000000   -0.757154    0.586295
    &END COORD
  &END SUBSYS
&END FORCE_EVAL