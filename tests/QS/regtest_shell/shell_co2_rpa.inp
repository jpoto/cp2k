&GLOBAL
  PRINT_LEVEL LOW
  PROJECT shell_co2_rpa
  RUN_TYPE ENERGY
&END GLOBAL

&FORCE_EVAL
  METHOD Quickstep
  &DFT
    BASIS_SET_FILE_NAME HFX_BASIS
    POTENTIAL_FILE_NAME GTH_POTENTIALS
    &MGRID
      CUTOFF 100
      REL_CUTOFF 20
    &END MGRID
    &POISSON
      PERIODIC NONE
      POISSON_SOLVER WAVELET
    &END POISSON
    &QS
      EPS_DEFAULT 1.0E-12
      METHOD GPW
    &END QS
    &SCF
      MAX_SCF 300
      EPS_SCF 1.0E-5
      SCF_GUESS ATOMIC
      IGNORE_CONVERGENCE_FAILURE
    &END SCF
    &XC
      &WF_CORRELATION
        MEMORY 50
        &RI_RPA
          RPA_NUM_QUAD_POINTS 4
          &HF
            FRACTION 1.0
            &SCREENING
              EPS_SCHWARZ 1.0E-6
            &END SCREENING
          &END HF
        &END RI_RPA
      &END WF_CORRELATION
      &XC_FUNCTIONAL PBE
      &END XC_FUNCTIONAL
    &END XC
  &END DFT
  &SUBSYS
    &CELL
      ABC 15.0 10.0 10.0
      PERIODIC NONE
    &END CELL
    &COORD
      C    0.000000    0.000000    0.000000
      O    1.160000    0.000000    0.000000
      O   -1.160000    0.000000    0.000000
    &END COORD
    &KIND C
      BASIS_SET DZVP-GTH
      BASIS_SET RI_AUX RI_DZVP-GTH
      POTENTIAL GTH-PBE-q4
    &END KIND
    &KIND O
      BASIS_SET DZVP-GTH
      BASIS_SET RI_AUX RI_DZVP-GTH
      POTENTIAL GTH-PBE-q6
    &END KIND
  &END SUBSYS
&END FORCE_EVAL