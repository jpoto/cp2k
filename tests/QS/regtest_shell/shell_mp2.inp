&GLOBAL
  PRINT_LEVEL LOW
  PROJECT shell_mp2
  RUN_TYPE ENERGY
&END GLOBAL

&FORCE_EVAL
  METHOD Quickstep
  &DFT
    BASIS_SET_FILE_NAME HFX_BASIS
    POTENTIAL_FILE_NAME GTH_POTENTIALS
    &MGRID
      CUTOFF 300
      REL_CUTOFF 40
    &END MGRID
    &POISSON
      PERIODIC NONE
      POISSON_SOLVER MT
    &END POISSON
    &QS
      EPS_DEFAULT 1.0E-12
      METHOD GPW
    &END QS
    &SCF
      MAX_SCF 50
      EPS_SCF 1.0E-5
      SCF_GUESS ATOMIC
      IGNORE_CONVERGENCE_FAILURE
    &END SCF
    &XC
      &HF
        FRACTION 1.0
        &SCREENING
          EPS_SCHWARZ 1.0E-6
        &END SCREENING
      &END HF
      &WF_CORRELATION
        MEMORY 50
        &MP2
          METHOD DIRECT_CANONICAL
        &END MP2
      &END WF_CORRELATION
      &XC_FUNCTIONAL NONE
      &END XC_FUNCTIONAL
    &END XC
  &END DFT
  &SUBSYS
    &CELL
      ABC 10.0 10.0 10.0
      PERIODIC NONE
    &END CELL
    &COORD
      O    0.000000    0.000000    0.000000
      H    0.000000    0.757154    0.586295
      H    0.000000   -0.757154    0.586295
    &END COORD
    &KIND O
      BASIS_SET DZVP-GTH
      BASIS_SET RI_AUX RI_DZVP-GTH
      POTENTIAL GTH-PBE-q6
    &END KIND
    &KIND H
      BASIS_SET DZVP-GTH
      BASIS_SET RI_AUX RI_DZVP-GTH
      POTENTIAL GTH-PBE-q1
    &END KIND
  &END SUBSYS
&END FORCE_EVAL