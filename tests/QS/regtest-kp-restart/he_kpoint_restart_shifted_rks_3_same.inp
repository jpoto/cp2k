#CPQA DEPENDS he_kpoint_restart_shifted_rks_3.inp
&GLOBAL
  PRINT_LEVEL LOW
  PROJECT HE_KPOINT_RESTART_SHIFTED_RKS_3_SAME
  RUN_TYPE ENERGY
&END GLOBAL

&FORCE_EVAL
  &DFT
    BASIS_SET_FILE_NAME BASIS_MOLOPT_UZH
    POTENTIAL_FILE_NAME POTENTIAL_UZH
    WFN_RESTART_FILE_NAME HE_KPOINT_RESTART_SHIFTED_RKS_3-RESTART.kp
    &KPOINTS
      FULL_GRID ON
      PARALLEL_GROUP_SIZE -1
      SCHEME MACDONALD 3 3 3 0.5 0.5 0.5
      SYMMETRY OFF
      WAVEFUNCTIONS COMPLEX
    &END KPOINTS
    &MGRID
      CUTOFF 100
      REL_CUTOFF 30
    &END MGRID
    &QS
      EPS_DEFAULT 1.0E-10
      METHOD GPW
    &END QS
    &SCF
      CHOLESKY OFF
      EPS_EIGVAL 1.0E-8
      EPS_SCF 1.0E-9
      KPOINT_RESTART_MODE EXACT
      MAX_SCF 100
      SCF_GUESS RESTART
      &MIXING
        ALPHA 0.50
        METHOD BROYDEN_MIXING
      &END MIXING
      &PRINT
        &RESTART OFF
        &END RESTART
      &END PRINT
    &END SCF
    &XC
      &XC_FUNCTIONAL PBE
      &END XC_FUNCTIONAL
    &END XC
  &END DFT
  &SUBSYS
    &CELL
      ABC 4.0 4.0 4.0
    &END CELL
    &COORD
      SCALED
      He 0.5 0.5 0.5
    &END COORD
    &KIND He
      BASIS_SET ORB DZVP-MOLOPT-GGA-GTH-q2
      POTENTIAL GTH-GGA-q2
    &END KIND
  &END SUBSYS
&END FORCE_EVAL
