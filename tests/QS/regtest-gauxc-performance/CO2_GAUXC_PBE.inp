&GLOBAL
  PRINT_LEVEL MEDIUM
  PROJECT_NAME CO2_GAUXC_PBE
  RUN_TYPE ENERGY
&END GLOBAL

&FORCE_EVAL
  &DFT
     BASIS_SET_FILE_NAME BASIS_MOLOPT
     POTENTIAL_FILE_NAME GTH_POTENTIALS
    UKS FALSE
    &MGRID
      CUTOFF 400
      REL_CUTOFF 50
    &END MGRID
      &POISSON
        PERIODIC NONE
        POISSON_SOLVER ANALYTIC
      &END POISSON
    &QS
      EPS_DEFAULT 1.0E-10
      EXTRAPOLATION USE_PREV_WF
    &END QS
     &SCF
       MAX_SCF 50
       &DIAGONALIZATION
       &END DIAGONALIZATION
     &END SCF
    &XC
      &XC_FUNCTIONAL
        &GAUXC
          FUNCTIONAL PBE
          MODEL PBE
        &END GAUXC
      &END XC_FUNCTIONAL
    &END XC
  &END DFT
  &SUBSYS
     &CELL
       ABC 15.0 15.0 15.0
       PERIODIC NONE
     &END CELL
    &COORD
       C     0.0  0.0  0.0
       O     1.2  0.0  0.0
       O    -1.2  0.0  0.0
    &END COORD
     &KIND C
       BASIS_SET DZVP-MOLOPT-GTH-q4
       POTENTIAL GTH-PBE-q4
     &END KIND
     &KIND O
       BASIS_SET DZVP-MOLOPT-GTH-q6
       POTENTIAL GTH-PBE-q6
     &END KIND
  &END SUBSYS
&END FORCE_EVAL
