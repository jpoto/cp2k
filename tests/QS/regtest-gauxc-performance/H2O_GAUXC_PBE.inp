&GLOBAL
  PRINT_LEVEL MEDIUM
  PROJECT_NAME H2O_GAUXC_PBE
  RUN_TYPE ENERGY
&END GLOBAL

&FORCE_EVAL
  &DFT
     BASIS_SET_FILE_NAME BASIS_MOLOPT
     POTENTIAL_FILE_NAME GTH_POTENTIALS
    UKS FALSE
    &MGRID
      CUTOFF 400
      REL_CUTOFF 50
    &END MGRID
      &POISSON
        PERIODIC NONE
        POISSON_SOLVER ANALYTIC
      &END POISSON
    &QS
      EPS_DEFAULT 1.0E-10
      EXTRAPOLATION USE_PREV_WF
    &END QS
     &SCF
       MAX_SCF 50
       &DIAGONALIZATION
       &END DIAGONALIZATION
     &END SCF
    &XC
      &XC_FUNCTIONAL
        &GAUXC
          FUNCTIONAL PBE
          MODEL PBE
        &END GAUXC
      &END XC_FUNCTIONAL
    &END XC
  &END DFT
  &SUBSYS
    &CELL
      ABC 20.0 20.0 20.0
      PERIODIC NONE
    &END CELL
    &COORD
       O     0.0  0.0  0.0
       H     1.0  0.0  0.0
       H    -0.5  0.866  0.0
    &END COORD
     &KIND O
       BASIS_SET DZVP-MOLOPT-GTH-q6
       POTENTIAL GTH-PBE-q6
     &END KIND
     &KIND H
       BASIS_SET DZVP-MOLOPT-GTH-q1
       POTENTIAL GTH-PBE-q1
     &END KIND
  &END SUBSYS
&END FORCE_EVAL
