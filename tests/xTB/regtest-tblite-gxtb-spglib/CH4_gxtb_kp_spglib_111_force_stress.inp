# Requires a CP2K build with SPGLIB support.
&GLOBAL
  PRINT_LEVEL MEDIUM
  PROJECT CH4_gxtb_kp_spglib_111_force_stress
  RUN_TYPE DEBUG
&END GLOBAL

&DEBUG
  CHECK_ATOM_FORCE 2 X
  DEBUG_FORCES T
  DEBUG_STRESS_TENSOR T
  DX 0.0001
  STOP_ON_MISMATCH F
&END DEBUG

&FORCE_EVAL
  METHOD QUICKSTEP
  STRESS_TENSOR ANALYTICAL
  &DFT
    &KPOINTS
      DEBUG_FULL_KPOINT_SYMMETRY T
      EPS_SYMMETRY 1.0E-8
      FULL_GRID OFF
      PARALLEL_GROUP_SIZE -1
      SCHEME MONKHORST-PACK 1 1 1
      SYMMETRY ON
      SYMMETRY_BACKEND SPGLIB
      SYMMETRY_REDUCTION_METHOD SPGLIB
      VERBOSE T
      WAVEFUNCTIONS COMPLEX
    &END KPOINTS
    &POISSON
      PERIODIC XYZ
      POISSON_SOLVER PERIODIC
    &END POISSON
    &QS
      EPS_DEFAULT 1.0E-12
      METHOD xTB
      &XTB
        GFN_TYPE TBLITE
        &TBLITE
          ACCURACY 1.0
          METHOD GXTB
        &END TBLITE
      &END XTB
    &END QS
    &SCF
      EPS_SCF 1.0E-10
      MAX_SCF 300
      SCF_GUESS MOPAC
      &MIXING
        ALPHA 0.2
        METHOD DIRECT_P_MIXING
      &END MIXING
      &PRINT
        &RESTART OFF
        &END RESTART
      &END PRINT
    &END SCF
  &END DFT
  &SUBSYS
    &CELL
      ABC 8.0 8.0 8.0
      CANONICALIZE TRUE
      PERIODIC XYZ
      SYMMETRY CUBIC
    &END CELL
    &COORD
      C 4.0000000000 4.0000000000 4.0000000000
      H 4.6928203230 4.6928203230 4.6928203230
      H 4.6928203230 3.3071796770 3.3071796770
      H 3.3071796770 4.6928203230 3.3071796770
      H 3.3071796770 3.3071796770 4.6928203230
    &END COORD
  &END SUBSYS
&END FORCE_EVAL
