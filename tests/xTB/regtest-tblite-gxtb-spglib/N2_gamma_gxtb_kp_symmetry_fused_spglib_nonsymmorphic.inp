# Requires a CP2K build with SPGLIB support.
&GLOBAL
  PRINT_LEVEL MEDIUM
  PROJECT N2_gamma_gxtb_kp_symmetry_fused_spglib_nonsymmorphic
  RUN_TYPE ENERGY_FORCE
&END GLOBAL

&FORCE_EVAL
  METHOD QUICKSTEP
  STRESS_TENSOR ANALYTICAL
  &DFT
    &KPOINTS
      EPS_SYMMETRY 1.0E-8
      FULL_GRID OFF
      PARALLEL_GROUP_SIZE -1
      SCHEME MONKHORST-PACK 3 3 3
      SYMMETRY ON
      SYMMETRY_BACKEND SPGLIB
      SYMMETRY_REDUCTION_METHOD SPGLIB
      VERBOSE ON
      WAVEFUNCTIONS COMPLEX
    &END KPOINTS
    &POISSON
      PERIODIC XYZ
      POISSON_SOLVER PERIODIC
    &END POISSON
    &QS
      EPS_DEFAULT 1.0E-12
      METHOD xTB
      &XTB
        GFN_TYPE TBLITE
        &TBLITE
          ACCURACY 1.0
          METHOD GXTB
          &GXTB_ACCELERATION
            ACP_PROJECTOR_CACHE QUALIFY
            EXCHANGE_STREAM_BACKEND SYMMETRY_FUSED
            FORWARD_FOCK_QUALIFICATION QUALIFY
            FOURIER_TRANSFORM_BACKEND MIXED_RADIX_FFT
            GRADIENT_CONTRACTION QUALIFY
            IMAGE_BATCH_SIZE 2
            SYMMETRY_STAR_CONTRACTION QUALIFY
          &END GXTB_ACCELERATION
        &END TBLITE
      &END XTB
    &END QS
    &SCF
      EPS_SCF 1.0E-10
      MAX_SCF 300
      SCF_GUESS MOPAC
      &MIXING
        ALPHA 0.2
        METHOD DIRECT_P_MIXING
      &END MIXING
      &PRINT
        &RESTART OFF
        &END RESTART
      &END PRINT
    &END SCF
  &END DFT
  &PRINT
    &FORCES ON
    &END FORCES
    &STRESS_TENSOR ON
      COMPONENTS
    &END STRESS_TENSOR
  &END PRINT
  &SUBSYS
    &CELL
      A 3.95700000 0.00000000 0.00000000
      B 0.00000000 3.95700000 0.00000000
      C 0.00000000 0.00000000 5.10900000
      CANONICALIZE TRUE
      PERIODIC XYZ
    &END CELL
    &COORD
      SCALED
      N  0.09800000  0.09800000 0.00000000
      N -0.09800000 -0.09800000 0.00000000
      N  0.40200000  0.59800000 0.50000000
      N  0.59800000  0.40200000 0.50000000
    &END COORD
  &END SUBSYS
&END FORCE_EVAL
