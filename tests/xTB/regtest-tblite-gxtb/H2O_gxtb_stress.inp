&GLOBAL
  PRINT_LEVEL MEDIUM
  PROJECT H2O_gxtb_stress
  RUN_TYPE DEBUG
&END GLOBAL

&DEBUG
  DEBUG_FORCES F
  DEBUG_STRESS_TENSOR T
  DX 0.00005
  MAX_RELATIVE_ERROR 0.5
  STOP_ON_MISMATCH F
&END DEBUG

&FORCE_EVAL
  STRESS_TENSOR ANALYTICAL
  &DFT
    &QS
      EPS_DEFAULT 1.0E-12
      METHOD xTB
      &XTB
        GFN_TYPE TBLITE
        &TBLITE
          ACCURACY 1.0
          METHOD GXTB
        &END TBLITE
      &END XTB
    &END QS
    &SCF
      EPS_SCF 1.0E-10
      MAX_SCF 300
      SCF_GUESS MOPAC
      &MIXING
        ALPHA 0.2
        METHOD DIRECT_P_MIXING
      &END MIXING
      &PRINT
        &RESTART OFF
        &END RESTART
      &END PRINT
    &END SCF
  &END DFT
  &SUBSYS
    &CELL
      A 7.800000 0.200000 0.100000
      B 0.400000 8.300000 0.300000
      C 0.100000 0.500000 9.100000
      PERIODIC XYZ
    &END CELL
    &COORD
      O 0.200000 0.300000 0.400000
      H 0.958602 0.300000 0.904284
      H 0.200000 0.300000 1.400000
    &END COORD
  &END SUBSYS
&END FORCE_EVAL
