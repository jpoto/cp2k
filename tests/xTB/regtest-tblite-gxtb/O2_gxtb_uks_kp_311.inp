&GLOBAL
  PRINT_LEVEL MEDIUM
  PROJECT O2_gxtb_uks_kp_311
  RUN_TYPE ENERGY
&END GLOBAL

&FORCE_EVAL
  METHOD QUICKSTEP
  &DFT
    MULTIPLICITY 3
    UKS T
    &KPOINTS
      FULL_GRID ON
      PARALLEL_GROUP_SIZE -1
      SCHEME MACDONALD 3 1 1 0.0 0.0 0.0
      SYMMETRY OFF
      WAVEFUNCTIONS COMPLEX
    &END KPOINTS
    &POISSON
      PERIODIC XYZ
      POISSON_SOLVER PERIODIC
    &END POISSON
    &QS
      EPS_DEFAULT 1.0E-12
      METHOD xTB
      &XTB
        GFN_TYPE TBLITE
        &TBLITE
          ACCURACY 1.0
          METHOD GXTB
        &END TBLITE
      &END XTB
    &END QS
    &SCF
      ADDED_MOS -1 -1
      EPS_SCF 1.0E-10
      MAX_SCF 300
      SCF_GUESS MOPAC
      &MIXING
        ALPHA 0.2
        METHOD DIRECT_P_MIXING
      &END MIXING
      &PRINT
        &RESTART OFF
        &END RESTART
      &END PRINT
      &SMEAR ON
        ELECTRONIC_TEMPERATURE 300
        FIXED_MAGNETIC_MOMENT -1
        METHOD FERMI_DIRAC
      &END SMEAR
    &END SCF
  &END DFT
  &SUBSYS
    &CELL
      A 6.200000 0.000000 0.000000
      B 0.400000 6.500000 0.000000
      C 0.200000 0.300000 6.800000
      PERIODIC XYZ
    &END CELL
    &COORD
      O 1.100000 1.300000 1.500000
      O 2.350000 1.550000 1.370000
    &END COORD
  &END SUBSYS
&END FORCE_EVAL
