&GLOBAL
  PRINT_LEVEL MEDIUM
  PROJECT Si_prim_gxtb_kp_shifted_full
  RUN_TYPE ENERGY_FORCE
&END GLOBAL

&FORCE_EVAL
  METHOD QS
  STRESS_TENSOR ANALYTICAL
  &DFT
    &KPOINTS
      FULL_GRID ON
      PARALLEL_GROUP_SIZE -1
      SCHEME MACDONALD 2 2 2 0.25 0.25 0.25
      SYMMETRY OFF
      VERBOSE T
    &END KPOINTS
    &POISSON
      PERIODIC XYZ
      POISSON_SOLVER PERIODIC
    &END POISSON
    &QS
      EPS_DEFAULT 1.0E-12
      METHOD xTB
      &XTB
        GFN_TYPE TBLITE
        &TBLITE
          ACCURACY 1.0
          METHOD GXTB
        &END TBLITE
      &END XTB
    &END QS
    &SCF
      ADDED_MOS -1 -1
      EPS_SCF 1.0E-10
      MAX_SCF 300
      SCF_GUESS MOPAC
      &MIXING
        ALPHA 0.2
        METHOD DIRECT_P_MIXING
      &END MIXING
      &PRINT
        &RESTART OFF
        &END RESTART
      &END PRINT
      &SMEAR ON
        ELECTRONIC_TEMPERATURE 300
        METHOD FERMI_DIRAC
      &END SMEAR
    &END SCF
  &END DFT
  &PRINT
    &FORCES ON
    &END FORCES
    &STRESS_TENSOR ON
      COMPONENTS
    &END STRESS_TENSOR
  &END PRINT
  &SUBSYS
    &CELL
      ABC 3.840296928624139 3.840296928624139 3.840296928624139
      ALPHA_BETA_GAMMA 60.0 60.0 60.0
      PERIODIC XYZ
    &END CELL
    &COORD
      SCALED
      Si 0.00 0.00 0.00
      Si 0.25 0.25 0.25
    &END COORD
  &END SUBSYS
&END FORCE_EVAL
