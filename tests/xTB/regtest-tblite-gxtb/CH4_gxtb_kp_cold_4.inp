&GLOBAL
  PRINT_LEVEL MEDIUM
  PROJECT CH4_gxtb_kp_cold_4
  RUN_TYPE ENERGY
&END GLOBAL

&FORCE_EVAL
  METHOD QUICKSTEP
  &DFT
    &KPOINTS
      EPS_SYMMETRY 1.0E-8
      FULL_GRID OFF
      PARALLEL_GROUP_SIZE -1
      SCHEME MONKHORST-PACK 4 4 4
      SYMMETRY ON
      SYMMETRY_BACKEND K290
      SYMMETRY_REDUCTION_METHOD K290
      WAVEFUNCTIONS COMPLEX
    &END KPOINTS
    &POISSON
      PERIODIC XYZ
      POISSON_SOLVER PERIODIC
    &END POISSON
    &QS
      EPS_DEFAULT 1.0E-12
      METHOD xTB
      &XTB
        GFN_TYPE TBLITE
        &TBLITE
          ACCURACY 1.0
          METHOD GXTB
        &END TBLITE
      &END XTB
    &END QS
    &SCF
      EPS_SCF 1.0E-10
      MAX_SCF 300
      SCF_GUESS MOPAC
      &MIXING
        ALPHA 0.2
        METHOD DIRECT_P_MIXING
      &END MIXING
      &PRINT
        &RESTART OFF
        &END RESTART
      &END PRINT
    &END SCF
  &END DFT
  &SUBSYS
    &CELL
      ABC 8.0 8.0 8.0
      CANONICALIZE TRUE
      PERIODIC XYZ
      SYMMETRY CUBIC
    &END CELL
    &COORD
      C 4.0000000000 4.0000000000 4.0000000000
      H 4.6928203230 4.6928203230 4.6928203230
      H 4.6928203230 3.3071796770 3.3071796770
      H 3.3071796770 4.6928203230 3.3071796770
      H 3.3071796770 3.3071796770 4.6928203230
    &END COORD
  &END SUBSYS
&END FORCE_EVAL
