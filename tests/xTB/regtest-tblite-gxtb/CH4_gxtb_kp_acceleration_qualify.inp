&GLOBAL
  PRINT_LEVEL MEDIUM
  PROJECT CH4_gxtb_kp_acceleration_qualify
  RUN_TYPE ENERGY_FORCE
&END GLOBAL

&FORCE_EVAL
  METHOD QUICKSTEP
  STRESS_TENSOR ANALYTICAL
  &DFT
    &KPOINTS
      EPS_SYMMETRY 1.0E-8
      FULL_GRID OFF
      PARALLEL_GROUP_SIZE -1
      SCHEME MONKHORST-PACK 2 2 2
      SYMMETRY ON
      SYMMETRY_BACKEND K290
      SYMMETRY_REDUCTION_METHOD K290
      WAVEFUNCTIONS COMPLEX
    &END KPOINTS
    &POISSON
      PERIODIC XYZ
      POISSON_SOLVER PERIODIC
    &END POISSON
    &QS
      EPS_DEFAULT 1.0E-12
      METHOD xTB
      &XTB
        GFN_TYPE TBLITE
        &TBLITE
          ACCURACY 1.0
          METHOD GXTB
          &GXTB_ACCELERATION
            ACP_MESH_CONTRACTION QUALIFY
            ACP_PROJECTOR_CACHE QUALIFY
            EXCHANGE_STREAM_BACKEND K_GROUP_PARTIAL_DISTRIBUTED_IMAGES
            FORWARD_FOCK_QUALIFICATION QUALIFY
            FOURIER_TRANSFORM_BACKEND MIXED_RADIX_FFT
            GRADIENT_CONTRACTION QUALIFY
            IMAGE_BATCH_SIZE 2
            SYMMETRY_STAR_CONTRACTION QUALIFY
          &END GXTB_ACCELERATION
        &END TBLITE
      &END XTB
    &END QS
    &SCF
      EPS_SCF 1.0E-10
      MAX_SCF 300
      SCF_GUESS MOPAC
      &MIXING
        ALPHA 0.2
        METHOD DIRECT_P_MIXING
      &END MIXING
      &PRINT
        &RESTART OFF
        &END RESTART
      &END PRINT
    &END SCF
  &END DFT
  &PRINT
    &FORCES ON
    &END FORCES
    &STRESS_TENSOR ON
      COMPONENTS
    &END STRESS_TENSOR
  &END PRINT
  &SUBSYS
    &CELL
      ABC 8.0 8.0 8.0
      CANONICALIZE TRUE
      PERIODIC XYZ
      SYMMETRY CUBIC
    &END CELL
    &COORD
      C 4.0000000000 4.0000000000 4.0000000000
      H 4.6928203230 4.6928203230 4.6928203230
      H 4.6928203230 3.3071796770 3.3071796770
      H 3.3071796770 4.6928203230 3.3071796770
      H 3.3071796770 3.3071796770 4.6928203230
    &END COORD
  &END SUBSYS
&END FORCE_EVAL
