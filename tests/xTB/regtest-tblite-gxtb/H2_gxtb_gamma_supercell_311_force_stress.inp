&GLOBAL
  PRINT_LEVEL MEDIUM
  PROJECT H2_gxtb_gamma_supercell_311_force_stress
  RUN_TYPE DEBUG
&END GLOBAL

&DEBUG
  DEBUG_FORCES T
  DEBUG_STRESS_TENSOR T
  DX 0.0001
  STOP_ON_MISMATCH F
&END DEBUG

&FORCE_EVAL
  METHOD QUICKSTEP
  STRESS_TENSOR ANALYTICAL
  &DFT
    &POISSON
      PERIODIC XYZ
      POISSON_SOLVER PERIODIC
    &END POISSON
    &QS
      EPS_DEFAULT 1.0E-12
      METHOD xTB
      &XTB
        GFN_TYPE TBLITE
        SCC_MIXER TBLITE
        &TBLITE
          ACCURACY 1.0
          METHOD GXTB
        &END TBLITE
      &END XTB
    &END QS
    &SCF
      EPS_SCF 1.0E-10
      MAX_SCF 200
      SCF_GUESS MOPAC
      &MIXING
        ALPHA 0.2
        METHOD DIRECT_P_MIXING
      &END MIXING
      &PRINT
        &RESTART OFF
        &END RESTART
      &END PRINT
    &END SCF
  &END DFT
  &SUBSYS
    &CELL
      A 12.300000 0.000000 0.000000
      B 0.350000 4.300000 0.000000
      C 0.200000 0.270000 4.600000
      PERIODIC XYZ
    &END CELL
    &COORD
      H 0.730000 0.910000 1.130000
      H 1.480000 1.120000 1.260000
      H 4.830000 0.910000 1.130000
      H 5.580000 1.120000 1.260000
      H 8.930000 0.910000 1.130000
      H 9.680000 1.120000 1.260000
    &END COORD
  &END SUBSYS
&END FORCE_EVAL
