&GLOBAL
  PRINT_LEVEL MEDIUM
  PROJECT H2_gxtb_2d_kp_symmetry_fused
  RUN_TYPE ENERGY_FORCE
&END GLOBAL

&FORCE_EVAL
  METHOD QUICKSTEP
  STRESS_TENSOR ANALYTICAL
  &DFT
    &KPOINTS
      FULL_GRID OFF
      INVERSION_SYMMETRY_ONLY ON
      PARALLEL_GROUP_SIZE -1
      SCHEME MACDONALD 3 1 3 0.0 0.0 0.0
      SYMMETRY OFF
      WAVEFUNCTIONS COMPLEX
    &END KPOINTS
    &QS
      EPS_DEFAULT 1.0E-12
      METHOD xTB
      &XTB
        GFN_TYPE TBLITE
        &TBLITE
          ACCURACY 1.0
          METHOD GXTB
          &GXTB_ACCELERATION
            ACP_MESH_CONTRACTION QUALIFY
            ACP_PROJECTOR_CACHE QUALIFY
            EXCHANGE_STREAM_BACKEND SYMMETRY_FUSED
            FORWARD_FOCK_QUALIFICATION QUALIFY
            FOURIER_TRANSFORM_BACKEND MIXED_RADIX_FFT
            GRADIENT_CONTRACTION QUALIFY
            IMAGE_BATCH_SIZE 2
            SYMMETRY_STAR_CONTRACTION QUALIFY
          &END GXTB_ACCELERATION
        &END TBLITE
      &END XTB
    &END QS
    &SCF
      EPS_SCF 1.0E-10
      MAX_SCF 300
      SCF_GUESS MOPAC
      &MIXING
        ALPHA 0.2
        METHOD DIRECT_P_MIXING
      &END MIXING
      &PRINT
        &RESTART OFF
        &END RESTART
      &END PRINT
    &END SCF
  &END DFT
  &PRINT
    &FORCES ON
    &END FORCES
    &STRESS_TENSOR ON
      COMPONENTS
    &END STRESS_TENSOR
  &END PRINT
  &SUBSYS
    &CELL
      ABC 5.500000 18.000000 5.700000
      PERIODIC XZ
    &END CELL
    &COORD
      H 1.100000 9.000000 1.500000
      H 2.000000 9.000000 2.000000
    &END COORD
  &END SUBSYS
&END FORCE_EVAL
