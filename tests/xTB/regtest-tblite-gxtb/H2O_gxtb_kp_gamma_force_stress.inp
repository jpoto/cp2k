# Paired with H2O_gxtb_gamma_force_stress.inp.  Apart from the
# explicit Gamma KPOINTS section the physical input is intentionally identical.
&GLOBAL
  PRINT_LEVEL MEDIUM
  PROJECT H2O_gxtb_kp_gamma_force_stress
  RUN_TYPE DEBUG
&END GLOBAL

&DEBUG
  DEBUG_FORCES T
  DEBUG_STRESS_TENSOR T
  DX 0.0001
  STOP_ON_MISMATCH F
&END DEBUG

&FORCE_EVAL
  METHOD QUICKSTEP
  STRESS_TENSOR ANALYTICAL
  &DFT
    &KPOINTS
      FULL_GRID ON
      SCHEME GAMMA
      SYMMETRY OFF
      WAVEFUNCTIONS COMPLEX
    &END KPOINTS
    &POISSON
      PERIODIC XYZ
      POISSON_SOLVER PERIODIC
    &END POISSON
    &QS
      EPS_DEFAULT 1.0E-12
      METHOD xTB
      &XTB
        GFN_TYPE TBLITE
        &TBLITE
          ACCURACY 1.0
          METHOD GXTB
        &END TBLITE
      &END XTB
    &END QS
    &SCF
      EPS_SCF 1.0E-10
      MAX_SCF 300
      SCF_GUESS MOPAC
      &MIXING
        ALPHA 0.2
        METHOD DIRECT_P_MIXING
      &END MIXING
      &PRINT
        &RESTART OFF
        &END RESTART
      &END PRINT
    &END SCF
  &END DFT
  &SUBSYS
    &CELL
      A 8.000000 0.000000 0.000000
      B 0.300000 8.400000 0.000000
      C 0.200000 0.400000 9.100000
      PERIODIC XYZ
    &END CELL
    &COORD
      O 1.831000 2.147000 2.593000
      H 2.612000 2.203000 3.071000
      H 1.096000 2.268000 3.142000
    &END COORD
  &END SUBSYS
&END FORCE_EVAL
