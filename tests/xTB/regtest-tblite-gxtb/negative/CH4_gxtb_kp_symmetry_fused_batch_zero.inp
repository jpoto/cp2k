&GLOBAL
  PRINT_LEVEL LOW
  PROJECT CH4_gxtb_kp_symmetry_fused_batch_zero
  RUN_TYPE ENERGY
&END GLOBAL

&FORCE_EVAL
  METHOD QUICKSTEP
  &DFT
    &KPOINTS
      FULL_GRID OFF
      SCHEME MONKHORST-PACK 3 3 3
      SYMMETRY ON
      SYMMETRY_BACKEND K290
      SYMMETRY_REDUCTION_METHOD K290
      WAVEFUNCTIONS COMPLEX
    &END KPOINTS
    &QS
      METHOD xTB
      &XTB
        GFN_TYPE TBLITE
        &TBLITE
          METHOD GXTB
          &GXTB_ACCELERATION
            EXCHANGE_STREAM_BACKEND SYMMETRY_FUSED
            IMAGE_BATCH_SIZE 0
          &END GXTB_ACCELERATION
        &END TBLITE
      &END XTB
    &END QS
    &SCF
      MAX_SCF 2
    &END SCF
  &END DFT
  &SUBSYS
    &CELL
      ABC 8.0 8.0 8.0
      PERIODIC XYZ
      SYMMETRY CUBIC
    &END CELL
    &COORD
      C 4.0000000000 4.0000000000 4.0000000000
      H 4.6928203230 4.6928203230 4.6928203230
      H 4.6928203230 3.3071796770 3.3071796770
      H 3.3071796770 4.6928203230 3.3071796770
      H 3.3071796770 3.3071796770 4.6928203230
    &END COORD
  &END SUBSYS
&END FORCE_EVAL
