&GLOBAL
  PRINT_LEVEL MEDIUM
  PROJECT dat_CO2_GFN2
  RUN_TYPE DEBUG
&END GLOBAL

&DEBUG
  DEBUG_FORCES T
  DEBUG_STRESS_TENSOR F
  DX 0.0001
  STOP_ON_MISMATCH F
&END DEBUG

&FORCE_EVAL
  &DFT
    &POISSON
      PERIODIC XYZ
    &END POISSON
    &PRINT
      &DERIVATIVES ON
      &END DERIVATIVES
    &END PRINT
    &QS
      EPS_DEFAULT 1.00E-12
      METHOD xTB
      &XTB
        &TBLITE
          METHOD GFN2
        &END TBLITE
      &END XTB
    &END QS
    &SCF
      !ADDED_MOS -1 -1
      EPS_SCF 1.e-8
      MAX_SCF 300
      &MIXING
        ALPHA 0.1
        METHOD DIRECT_P_MIXING
      &END MIXING
      !&SMEAR ON
      !  ELECTRONIC_TEMPERATURE 300
      !  METHOD Fermi_Dirac
      !&END SMEAR
    &END SCF
  &END DFT
  &PRINT
    &FORCES ON
    &END FORCES
  &END PRINT
  &SUBSYS
    &CELL
      A  5.7903453   0.0000000   0.0000000  
      B  0.0000000   5.7903453   0.0000000 
      C  0.0000000   0.0000000   5.7903453
      PERIODIC XYZ
      MULTIPLE_UNIT_CELL  1  1  1
    &END CELL
    &COORD
C       0.00000 0.00000 0.00000 0.83473
C       2.89520 0.00000 2.89520 0.83473
C       2.89520 2.89520 0.00000 0.83473
C       0.00000 2.89520 2.89520 0.83473
O       0.67450 0.67450 0.67450 0.90184
O       3.56960 0.67450 2.22070 0.90184
O       3.56960 2.22070 5.11590 0.90184
O       5.11590 3.56960 2.22070 0.90184
O       5.11590 5.11590 5.11590 0.90184
O       2.22070 5.11590 3.56960 0.90184
O       2.22070 3.56960 0.67450 0.90184
O       0.67450 2.22070 3.56960 0.90184
    &END COORD
    &TOPOLOGY
      MULTIPLE_UNIT_CELL  1  1  1
    &END TOPOLOGY
  &END SUBSYS
&END FORCE_EVAL
