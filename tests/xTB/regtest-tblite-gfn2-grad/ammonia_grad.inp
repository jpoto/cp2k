&GLOBAL
  PRINT_LEVEL MEDIUM
  PROJECT dat_NH3
  RUN_TYPE DEBUG
&END GLOBAL

&DEBUG
  DEBUG_FORCES T
  DEBUG_STRESS_TENSOR F
  DX 0.0001
  MAX_RELATIVE_ERROR 0.5
  STOP_ON_MISMATCH F
&END DEBUG

&FORCE_EVAL
  &DFT
    &POISSON
      PERIODIC XYZ
      POISSON_SOLVER PERIODIC
    &END POISSON
    &PRINT
      &DERIVATIVES ON
      &END DERIVATIVES
    &END PRINT
    &QS
      METHOD xTB
      &XTB
        &TBLITE
          METHOD GFN2
        &END TBLITE
      &END XTB
    &END QS
    &SCF
      !ADDED_MOS -1 -1
      EPS_SCF 1.e-8
      MAX_SCF 300
      &MIXING
        ALPHA 0.1
        METHOD DIRECT_P_MIXING
      &END MIXING
      !&SMEAR ON
      !  ELECTRONIC_TEMPERATURE 300
      !  METHOD Fermi_Dirac
      !&END SMEAR
    &END SCF
  &END DFT
  &PRINT
    &FORCES ON
    &END FORCES
  &END PRINT
  &SUBSYS
    &CELL
      ABC  4.96216369999999  4.96216369999999  4.96216369999999
      PERIODIC XYZ
    &END CELL
    &COORD
  H      1.85960    1.35580    0.52320
  H      1.35580    0.52320    1.85960
  H      0.52320    1.85960    1.35580
  N      1.03420    1.03420    1.03420
    &END COORD
  &END SUBSYS
&END FORCE_EVAL
