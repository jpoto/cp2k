&GLOBAL
  PROJECT h2o_test
  RUN_TYPE ENERGY_FORCE
&

&FORCE_EVAL
  METHOD Quickstep
  &DFT
    BASIS_SET_FILE_NAME BASIS_MOLOPT
    POTENTIAL_FILE_NAME GTH_POTENTIALS
    
    &QS
      METHOD GPW
    &
    
    &SCF
      MAX_SCF 50
      EPS_SCF 1.0E-6
      SCF_GUESS ATOMIC
    &
    
    &XC
      &XC_FUNCTIONAL PBE
      &
    &
  &
  
  &SUBSYS
    &CELL
      ABC 10.0 10.0 10.0
      PERIODIC NONE
    &
    &COORD
      O    0.00000000    0.00000000    0.00000000
      H    0.95800000    0.00000000    0.00000000
      H    0.00000000    0.95800000    0.00000000
    &
    &KIND O
      ELEMENT O
      BASIS_SET DZVP-MOLOPT-SR-GTH
      POTENTIAL GTH-PBE
    &
    &KIND H
      ELEMENT H
      BASIS_SET DZVP-MOLOPT-SR-GTH
      POTENTIAL GTH-PBE
    &
  &
&
